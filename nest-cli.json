{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/sekolah-monorepo/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/sekolah-monorepo/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/sekolah-monorepo",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "sekolah-monorepo": {
      "type": "application",
      "root": "apps/sekolah-monorepo",
      "entryFile": "main",
      "sourceRoot": "apps/sekolah-monorepo/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sekolah-monorepo/tsconfig.app.json"
      }
    },
    "service-berita": {
      "type": "application",
      "root": "apps/service-berita",
      "entryFile": "main",
      "sourceRoot": "apps/service-berita/src",
      "compilerOptions": {
        "tsConfigPath": "apps/service-berita/tsconfig.app.json"
      }
    },
    "service-management": {
      "type": "application",
      "root": "apps/service-management",
      "entryFile": "main",
      "sourceRoot": "apps/service-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/service-management/tsconfig.app.json"
      }
    },
    "service-pelanggaran": {
      "type": "application",
      "root": "apps/service-pelanggaran",
      "entryFile": "main",
      "sourceRoot": "apps/service-pelanggaran/src",
      "compilerOptions": {
        "tsConfigPath": "apps/service-pelanggaran/tsconfig.app.json",
        "webpack": false
      }
    },
    "service-portofolio": {
      "type": "application",
      "root": "apps/service-portofolio",
      "entryFile": "main",
      "sourceRoot": "apps/service-portofolio/src",
      "compilerOptions": {
        "tsConfigPath": "apps/service-portofolio/tsconfig.app.json"
      }
    },
    "service-profile": {
      "type": "application",
      "root": "apps/service-profile",
      "entryFile": "main",
      "sourceRoot": "apps/service-profile/src",
      "compilerOptions": {
        "tsConfigPath": "apps/service-profile/tsconfig.app.json"
      }
    }
  }
}